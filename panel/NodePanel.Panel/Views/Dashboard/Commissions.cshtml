@model IReadOnlyList<NodePanel.Panel.Models.CommissionLogViewModel>
@{
    ViewData["Title"] = "返利流水 (Commission Logs)";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Affiliates</p>
        <h2>返利流水</h2>
        <p class="muted">查看用户的邀请佣金记录。</p>
    </div>
</section>

<section class="card">
    <table class="table" style="width: 100%;">
        <thead>
            <tr>
                <th style="font-weight: 500; text-align: left;">Order ID</th>
                <th style="width: 320px; font-weight: 500; text-align: left;">Invite User ID</th>
                <th style="width: 140px; font-weight: 500; text-align: right;">Trade Amount</th>
                <th style="width: 140px; font-weight: 500; text-align: right;">Commission</th>
                <th style="width: 160px; font-weight: 500; text-align: right;">Created At</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="muted" style="text-align: center; padding: 24px;">暂无返利记录</td></tr>
            }
            @foreach (var log in Model)
            {
                <tr>
                    <td style="text-align: left;"><span class="mono">@(log.OrderId.Length > 12 ? log.OrderId[..12] + "..." : log.OrderId)</span></td>
                    <td style="text-align: left;"><span class="mono muted">@log.InviteUserId</span></td>
                    <td class="mono" style="text-align: right; color: var(--admin-accent);">¥@log.TradeAmount.ToString("N2")</td>
                    <td class="mono" style="text-align: right; color: var(--admin-success);">+¥@log.CommissionAmount.ToString("N2")</td>
                    <td class="mono" style="text-align: right; color: var(--admin-fg-muted);">@log.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</section>
