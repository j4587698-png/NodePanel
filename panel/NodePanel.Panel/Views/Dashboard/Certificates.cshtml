@model CertificateListPageViewModel
@{
    ViewData["Title"] = "证书管理";
    var returnUrl = Url.Action("Certificates", "Dashboard") ?? "/admin/certificates";
}

@functions {
    private static string GetAssetMessageClass(PanelCertificateAssetState assetState)
        => assetState.HasUsableAsset ? "inline-alert inline-alert--warn" : "inline-alert inline-alert--error";

    private static string GetRuntimeMessageClass(PanelCertificateRuntimeStatusView runtimeStatus)
        => runtimeStatus.IsRunning || runtimeStatus.BadgeClass == "badge badge--warn"
            ? "inline-alert inline-alert--warn"
            : runtimeStatus.BadgeClass == "badge badge--error"
                ? "inline-alert inline-alert--error"
                : "muted";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Certificates</p>
        <h2>证书管理</h2>
        <p class="muted">这里统一处理 Panel 自身 HTTPS 和节点分发证书。`http-01` 适合域名直接指向面板，`dns-01` 适合泛域名和统一下发。</p>
    </div>
    <div class="page-actions">
        <a class="button button--primary" asp-action="NewCertificate">新建证书</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice">@Model.StatusMessage</div>
}

@if (Model.ShouldAutoRefresh)
{
    <div class="inline-alert inline-alert--warn">检测到证书任务正在执行，页面会在未编辑表单时自动刷新。</div>
}

<div class="grid grid--two certificates-layout">
    <section class="card certificates-layout__primary">
        <div class="card__header">
            <div>
                <p class="eyebrow">Panel HTTPS</p>
                <h3>面板 HTTPS</h3>
            </div>
            <p class="muted">如果没有显式传入监听配置，Linux 安装脚本默认会同时开放 `http://0.0.0.0:80` 和 `https://0.0.0.0:443`；本地开发环境则继续遵循 `launchSettings.json`。</p>
        </div>
        <form asp-action="SavePanelHttpsSettings" method="post" class="form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="error-box"></div>
            <div class="form-grid certificates-form-grid">
                <label>
                    <span>正式证书</span>
                    <select asp-for="PanelHttps.CertificateId">
                        <option value="">不绑定正式证书（使用自签）</option>
                        @foreach (var certificate in Model.Certificates)
                        {
                            <option value="@certificate.Definition.CertificateId">@certificate.Definition.DisplayName (@certificate.Definition.Domain)</option>
                        }
                    </select>
                </label>
                <div class="checkbox-field">
                    <span>HTTP 跳转 HTTPS</span>
                    <label class="switch">
                        <input asp-for="PanelHttps.RedirectHttpToHttps" type="checkbox" />
                        <span class="switch-slider"></span>
                    </label>
                </div>
            </div>
            <p class="muted">TLS 证书选择和 HTTP 跳转规则在保存后立即生效。未绑定可用正式证书时，面板会临时返回自签证书。</p>
            <p class="muted">监听地址和端口由 `ASPNETCORE_URLS`、`--urls`、`launchSettings.json` 或 Kestrel 端点配置统一控制；这里仅负责绑定面板证书和配置 HTTP 到 HTTPS 的跳转规则。</p>
            <div class="page-actions">
                <button type="submit" class="button button--primary">保存 HTTPS 设置</button>
            </div>
        </form>
    </section>

    <section class="card">
        <div class="card__header">
            <div>
                <p class="eyebrow">Notes</p>
                <h3>使用说明</h3>
            </div>
        </div>
        <div class="form">
            <p class="muted">节点 `acme-managed` 继续由节点自己跑 `http-01`。</p>
            <p class="muted">节点 `panel-distributed` 只消费面板下发的 PFX，续签后会自动重新推送快照。</p>
            <p class="muted">泛域名请使用 `dns-01`，并在证书配置里填写 DNS hook 命令。</p>
            <p class="muted">Panel HTTPS 的监听地址和端口不再由面板管理；如需调整，请修改 ASP.NET Core 宿主配置后重启进程。</p>
        </div>
    </section>
</div>

<section class="card">
    <div class="card__header">
        <div>
            <p class="eyebrow">Catalog</p>
            <h3>证书列表</h3>
        </div>
        <span class="metric">@Model.Certificates.Count</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>证书</th>
                    <th>Challenge</th>
                    <th>状态</th>
                    <th>绑定</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var certificate in Model.Certificates)
            {
                var definition = certificate.Definition;
                var assetState = certificate.AssetState;
                var runtimeStatus = certificate.RuntimeStatus;
                <tr>
                    <td>
                        <strong>@definition.DisplayName</strong>
                        <div class="muted mono">@definition.CertificateId</div>
                        <div class="muted">@definition.Domain</div>
                        @if (definition.AltNames.Count > 0)
                        {
                            <div class="muted">SAN: @string.Join(", ", definition.AltNames)</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(definition.LastError))
                        {
                            <div class="inline-alert inline-alert--error">@definition.LastError</div>
                        }
                    </td>
                    <td>
                        <div>@definition.ChallengeType</div>
                        <div class="muted">检查间隔 @definition.CheckIntervalMinutes 分钟</div>
                        <div class="muted">提前 @definition.RenewBeforeDays 天续签</div>
                    </td>
                    <td>
                        <span class="@assetState.BadgeClass">@assetState.Label</span>
                        @if (!string.IsNullOrWhiteSpace(assetState.Message))
                        {
                            <div class="@GetAssetMessageClass(assetState)">@assetState.Message</div>
                        }
                        <div style="margin-top: 10px;">
                            <span class="@runtimeStatus.BadgeClass">@runtimeStatus.Label</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(runtimeStatus.Message))
                        {
                            <div class="@GetRuntimeMessageClass(runtimeStatus)">@runtimeStatus.Message</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(runtimeStatus.Detail))
                        {
                            <div class="muted">@runtimeStatus.Detail</div>
                        }
                        <div class="muted">有效期 @((definition.NotAfter?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")) ?? "-")</div>
                        <div class="muted">最近尝试 @((definition.LastAttemptAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")) ?? "-")</div>
                        <div class="muted">上次成功 @((definition.LastSuccessAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")) ?? "-")</div>
                        @if (runtimeStatus.NextAutomaticRunAt is not null)
                        {
                            <div class="muted">下次自动处理 @runtimeStatus.NextAutomaticRunAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(definition.Thumbprint))
                        {
                            <div class="muted mono">Thumbprint @definition.Thumbprint</div>
                        }
                    </td>
                    <td>
                        <div>节点数: @certificate.BoundNodeCount</div>
                        <div class="muted">Panel HTTPS: @(certificate.UsedByPanelHttps ? "是" : "否")</div>
                    </td>
                    <td class="table-actions">
                        <form asp-action="RenewCertificate" asp-route-certificateId="@definition.CertificateId" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="button button--small">签发/续签</button>
                        </form>
                        <a class="button button--small" asp-action="Certificate" asp-route-certificateId="@definition.CertificateId">编辑</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
@if (Model.ShouldAutoRefresh)
{
<script>
    document.addEventListener('DOMContentLoaded', () => {
        let isDirty = false;
        document.querySelectorAll('input, select, textarea').forEach((element) => {
            element.addEventListener('input', () => { isDirty = true; });
            element.addEventListener('change', () => { isDirty = true; });
        });

        window.setInterval(() => {
            if (!document.hidden && !isDirty) {
                window.location.reload();
            }
        }, 3000);
    });
</script>
}
}
