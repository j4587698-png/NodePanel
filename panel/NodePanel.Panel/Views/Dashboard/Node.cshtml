<template id="outbound-template">
    <div class="config-collection__item" data-collection-item>
        <div class="config-collection__header">
            <strong>出站 <span data-item-number></span></strong>
            <button type="button" class="button button--small" data-remove-collection-item>移除</button>
        </div>
        <div class="toggle-grid">
            <div class="checkbox-field">
                <span>启用</span>
                <label class="switch">
                    <input type="checkbox" data-name-template="Form.Outbounds[__INDEX__].Enabled" value="true" checked="true" />
                    <span class="switch-slider"></span>
                </label>
            </div>
            <div class="checkbox-field">
                <span>启用多路复用</span>
                <label class="switch">
                    <input type="checkbox" data-name-template="Form.Outbounds[__INDEX__].MultiplexEnabled" value="true" />
                    <span class="switch-slider"></span>
                </label>
            </div>
            <div class="checkbox-field">
                <span>跳过证书校验</span>
                <label class="switch">
                    <input type="checkbox" data-name-template="Form.Outbounds[__INDEX__].SkipCertificateValidation" value="true" />
                    <span class="switch-slider"></span>
                </label>
            </div>
        </div>
        <div class="config-subgrid">
            <div class="form-grid">
                <label><span>Tag</span><input data-name-template="Form.Outbounds[__INDEX__].Tag" placeholder="proxy" /></label>
                <label>
                    <span>协议</span>
                    <select data-name-template="Form.Outbounds[__INDEX__].Protocol">
                        @foreach (var option in outboundProtocolOptions)
                        {
                            <option value="@option" selected="@(option == OutboundProtocols.Freedom)">@option</option>
                        }
                    </select>
                </label>
                <label><span>Via</span><input data-name-template="Form.Outbounds[__INDEX__].Via" placeholder="eth0 / 192.0.2.10" /></label>
                <label><span>Via CIDR</span><input data-name-template="Form.Outbounds[__INDEX__].ViaCidr" placeholder="192.0.2.0/24" /></label>
                <label>
                    <span>Target Strategy</span>
                    <select data-name-template="Form.Outbounds[__INDEX__].TargetStrategy">
                        @foreach (var option in outboundTargetStrategyOptions)
                        {
                            <option value="@option" selected="@(option == OutboundTargetStrategies.AsIs)">@option</option>
                        }
                    </select>
                </label>
                <label><span>代理出站 Tag</span><input data-name-template="Form.Outbounds[__INDEX__].ProxyOutboundTag" placeholder="upstream-proxy" /></label>
            </div>
            <div class="section-divider"></div>
            <div class="form-grid">
                <label>
                    <span>传输</span>
                    <select data-name-template="Form.Outbounds[__INDEX__].Transport">
                        @foreach (var option in outboundTransportOptions)
                        {
                            <option value="@option" selected="@(option == TrojanOutboundTransports.Tls)">@option</option>
                        }
                    </select>
                </label>
                <label><span>远端主机</span><input data-name-template="Form.Outbounds[__INDEX__].ServerHost" placeholder="edge.example.com" /></label>
                <label><span>远端端口</span><input data-name-template="Form.Outbounds[__INDEX__].ServerPort" value="443" /></label>
                <label><span>SNI / ServerName</span><input data-name-template="Form.Outbounds[__INDEX__].ServerName" placeholder="edge.example.com" /></label>
                <label><span>应用层协议 (CSV)</span><input data-name-template="Form.Outbounds[__INDEX__].ApplicationProtocols" placeholder="h2, http/1.1" /></label>
                <label><span>密码</span><input data-name-template="Form.Outbounds[__INDEX__].Password" /></label>
                <label><span>连接超时(秒)</span><input data-name-template="Form.Outbounds[__INDEX__].ConnectTimeoutSeconds" value="0" /></label>
                <label><span>握手超时(秒)</span><input data-name-template="Form.Outbounds[__INDEX__].HandshakeTimeoutSeconds" value="0" /></label>
            </div>
            <div class="section-divider"></div>
            <div class="form-grid">
                <label><span>WS 路径</span><input data-name-template="Form.Outbounds[__INDEX__].WebSocketPath" placeholder="/ws" /></label>
                <label><span>WS Early Data 字节数</span><input data-name-template="Form.Outbounds[__INDEX__].WebSocketEarlyDataBytes" value="0" /></label>
                <label><span>WS 心跳周期(秒)</span><input data-name-template="Form.Outbounds[__INDEX__].WebSocketHeartbeatPeriodSeconds" value="0" /></label>
                <label><span>多路复用并发</span><input data-name-template="Form.Outbounds[__INDEX__].MultiplexConcurrency" value="0" /></label>
                <label><span>XUDP 并发</span><input data-name-template="Form.Outbounds[__INDEX__].MultiplexXudpConcurrency" value="0" /></label>
                <label>
                    <span>XUDP UDP/443</span>
                    <select data-name-template="Form.Outbounds[__INDEX__].MultiplexXudpProxyUdp443">
                        @foreach (var option in xudpProxyModes)
                        {
                            <option value="@option" selected="@(option == OutboundXudpProxyModes.Reject)">@option</option>
                        }
                    </select>
                </label>
            </div>
            <label>
                <span>WS 请求头</span>
                <textarea data-name-template="Form.Outbounds[__INDEX__].WebSocketHeadersText" rows="5" placeholder="Host=edge.example.com&#10;X-Node=panel"></textarea>
                <small class="muted mono">每行一个 KEY=VALUE。</small>
            </label>
        </div>
    </div>
</template>

