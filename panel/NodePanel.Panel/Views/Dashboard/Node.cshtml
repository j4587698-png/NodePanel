                </label>
            </div>
        </div>
        <div class="form-grid">
            <label><span>入站 Tags (CSV)</span><input data-name-template="Form.RoutingRules[__INDEX__].InboundTags" placeholder="trojan-tcp-tls, trojan-wss" /></label>
            <label><span>协议 (CSV)</span><input data-name-template="Form.RoutingRules[__INDEX__].Protocols" placeholder="http, tls, bittorrent" /></label>
