<script>
    function toggleNodeGroupDropdown(event) {
        if (event) {
            event.stopPropagation();
        }

        const dropdown = document.getElementById('nodeGroupDropdown');
        if (dropdown) {
            dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        }
    }

    function updateNodeGroupIds() {
        const checkboxes = document.querySelectorAll('.node-group-checkbox:checked');
        const ids = Array.from(checkboxes).map((checkbox) => checkbox.value).join(',');
        const names = Array.from(checkboxes).map((checkbox) => checkbox.getAttribute('data-name')).join(', ');
        
        const hiddenInput = document.getElementById('nodeGroupIdsHidden');
        if (hiddenInput) {
            hiddenInput.value = ids;
        }
        
        const textSpan = document.getElementById('nodeGroupSelectedText');
        if (textSpan) {
            textSpan.textContent = names || '点击选择权限组...';
        }
    }

    function reindexCollection(container) {
        if (!container) {
            return;
        }

        const items = container.querySelectorAll('[data-collection-item]');
        items.forEach((item, index) => {
            item.querySelectorAll('[data-name-template]').forEach((field) => {
                const template = field.getAttribute('data-name-template');
                if (template) {
                    field.name = template.replace(/__INDEX__/g, index);
                }
            });

            item.querySelectorAll('[data-item-number]').forEach((label) => {
                label.textContent = String(index + 1);
            });
        });
    }

    function addCollectionItem(containerId, templateId) {
        const container = document.getElementById(containerId);
        const template = document.getElementById(templateId);
        if (!container || !template || !('content' in template)) {
            return;
        }

        container.appendChild(template.content.cloneNode(true));
        reindexCollection(container);
    }

    function readBooleanInputValue(input) {
        return !!input && String(input.value).toLowerCase() === 'true';
    }

    function toggleElements(selector, shouldShow, displayValue = 'block') {
        document.querySelectorAll(selector).forEach((element) => {
            element.style.display = shouldShow ? displayValue : 'none';
        });
    }

    function updateTransportMode() {
        const transportMode = document.getElementById('transportMode');
        const tlsPanel = document.getElementById('tls-panel');
        const wssPanel = document.getElementById('wss-panel');
        const tlsEnabledInput = document.getElementById('tlsEnabledInput');
        const wssEnabledInput = document.getElementById('wssEnabledInput');
        if (!transportMode || !tlsPanel || !wssPanel || !tlsEnabledInput || !wssEnabledInput) {
            return;
        }

        const mode = transportMode.value;
        const enableTls = mode === 'tls' || mode === 'both';
        const enableWss = mode === 'wss' || mode === 'both';
        tlsEnabledInput.value = enableTls ? 'true' : 'false';
        wssEnabledInput.value = enableWss ? 'true' : 'false';
        tlsPanel.classList.toggle('is-hidden', !enableTls);
        wssPanel.classList.toggle('is-hidden', !enableWss);
    }

    function syncPrimaryDomain() {
        const primaryDomainInput = document.getElementById('primaryDomainInput');
        const wssHostInput = document.getElementById('wssHostInput');
        if (!primaryDomainInput || !wssHostInput) {
            return;
        }

        if (!primaryDomainInput.value.trim() && wssHostInput.value.trim()) {
            primaryDomainInput.value = wssHostInput.value.trim();
        }

        wssHostInput.value = primaryDomainInput.value.trim();
    }

    function syncPanelCertificateDomain(force) {
        const certificateModeInput = document.getElementById('certificateModeInput');
        const panelCertificateInput = document.getElementById('Form_PanelCertificateId');
        const primaryDomainInput = document.getElementById('primaryDomainInput');
        if (!certificateModeInput || !panelCertificateInput || !primaryDomainInput) {
            return;
        }

        if (certificateModeInput.value !== 'panel-distributed') {
            return;
        }

        const selectedOption = panelCertificateInput.options[panelCertificateInput.selectedIndex];
        const selectedDomain = selectedOption?.dataset?.domain?.trim() ?? '';
        if (!selectedDomain) {
            return;
        }

        if (force || !primaryDomainInput.value.trim()) {
            primaryDomainInput.value = selectedDomain;
        }

        syncPrimaryDomain();
    }

    function getDefaultCertificateMode() {
        const panelCertificateInput = document.getElementById('Form_PanelCertificateId');
        if (panelCertificateInput && panelCertificateInput.options.length > 1) {
            return 'panel-distributed';
        }

        return 'acme-managed';
    }

    function syncCertificateModeUi() {
        const certificateModeInput = document.getElementById('certificateModeInput');
        const certificateCompatMode = document.getElementById('certificateCompatMode');
        const presetInputs = Array.from(document.querySelectorAll('[name="certificateModePreset"]'));
        if (!certificateModeInput) {
            return;
        }

        const mode = certificateModeInput.value.trim();
        const isPresetMode = presetInputs.some((input) => input.value === mode);

        presetInputs.forEach((input) => {
            input.checked = input.value === mode;
        });

        document.querySelectorAll('[data-certificate-mode-option]').forEach((element) => {
            element.classList.toggle('is-active', element.getAttribute('data-certificate-mode-option') === mode);
        });

        if (!certificateCompatMode) {
            return;
        }

        if (isPresetMode) {
            certificateCompatMode.value = '';
            return;
        }

        const matchedOption = Array.from(certificateCompatMode.options).some((option) => option.value === mode);
        certificateCompatMode.value = matchedOption ? mode : '';
    }

    function setCertificateMode(mode) {
        const certificateModeInput = document.getElementById('certificateModeInput');
        if (!certificateModeInput) {
            return;
        }

        certificateModeInput.value = (mode ?? '').trim() || getDefaultCertificateMode();
        updateCertificateModeVisibility();
        syncCertificateModeUi();
    }

    function updateCertificateModeVisibility() {
        const certificateModeInput = document.getElementById('certificateModeInput');
        const certificateChallengeInput = document.getElementById('Form_CertificateChallengeType');
        if (!certificateModeInput) {
            return;
        }

        const mode = certificateModeInput.value;
        toggleElements('.cert-manual-field', mode === 'manual-pfx');
        toggleElements('.cert-acme-field', mode === 'acme-managed');
        toggleElements('.cert-panel-field', mode === 'panel-distributed');
        toggleElements('.cert-external-field', mode === 'acme-external');

        if (certificateChallengeInput && mode === 'acme-managed') {
            certificateChallengeInput.value = 'http-01';
        }

        if (mode === 'panel-distributed') {
            syncPanelCertificateDomain(false);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        updateNodeGroupIds();
        document.querySelectorAll('[data-collection]').forEach((container) => reindexCollection(container));

        const transportMode = document.getElementById('transportMode');
        const tlsEnabledInput = document.getElementById('tlsEnabledInput');
        const wssEnabledInput = document.getElementById('wssEnabledInput');
        if (transportMode && tlsEnabledInput && wssEnabledInput) {
            if (readBooleanInputValue(tlsEnabledInput) && readBooleanInputValue(wssEnabledInput)) {
                transportMode.value = 'both';
            }
            else if (readBooleanInputValue(wssEnabledInput)) {
                transportMode.value = 'wss';
            }
            else {
                transportMode.value = 'tls';
            }

            transportMode.addEventListener('change', updateTransportMode);
            updateTransportMode();
        }

        const certificateModeInput = document.getElementById('certificateModeInput');
        const certificateCompatMode = document.getElementById('certificateCompatMode');
        if (certificateModeInput) {
            const presetInputs = document.querySelectorAll('[name="certificateModePreset"]');

            certificateModeInput.addEventListener('change', () => {
                updateCertificateModeVisibility();
                syncCertificateModeUi();
            });

            presetInputs.forEach((input) => {
                input.addEventListener('change', () => {
                    if (input.checked) {
                        setCertificateMode(input.value);
                    }
                });
            });

            if (certificateCompatMode) {
                certificateCompatMode.addEventListener('change', () => {
                    setCertificateMode(certificateCompatMode.value);
                });
            }

            if (!certificateModeInput.value.trim()) {
                setCertificateMode(getDefaultCertificateMode());
            }
            else {
                syncCertificateModeUi();
                updateCertificateModeVisibility();
            }
        }

        const primaryDomainInput = document.getElementById('primaryDomainInput');
        if (primaryDomainInput) {
            primaryDomainInput.addEventListener('input', syncPrimaryDomain);
            syncPrimaryDomain();
        }

        const panelCertificateInput = document.getElementById('Form_PanelCertificateId');
        if (panelCertificateInput) {
            panelCertificateInput.addEventListener('change', () => syncPanelCertificateDomain(true));
            syncPanelCertificateDomain(false);
        }

        document.addEventListener('click', (event) => {
            const addButton = event.target.closest('[data-add-collection]');
            if (addButton) {
                addCollectionItem(addButton.getAttribute('data-add-collection'), addButton.getAttribute('data-template-id'));
                return;
            }

            const removeButton = event.target.closest('[data-remove-collection-item]');
            if (removeButton) {
                const item = removeButton.closest('[data-collection-item]');
                const container = item ? item.closest('[data-collection]') : null;
                if (item) {
                    item.remove();
                }

                if (container) {
                    reindexCollection(container);
                }
                return;
            }

            const wrapper = document.querySelector('.custom-select-wrapper');
            const dropdown = document.getElementById('nodeGroupDropdown');
            if (wrapper && dropdown && !wrapper.contains(event.target)) {
                dropdown.style.display = 'none';
            }
        });
    });
</script>
