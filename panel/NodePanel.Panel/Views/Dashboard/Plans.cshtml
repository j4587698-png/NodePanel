@using NodePanel.Panel.Models
@model DashboardPageViewModel
@{
    ViewData["Title"] = "订阅套餐";
    var currency = Model.State.Settings.GetValueOrDefault("currency_symbol", "¥");
    if (string.IsNullOrWhiteSpace(currency)) currency = "¥";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Plans</p>
        <h2>订阅套餐</h2>
        <p class="muted">管理提供给用户的订阅套餐及其定价、流量配额与周期。</p>
    </div>
    <div class="page-actions">
        <a class="button button--primary" asp-action="NewPlan">新建套餐</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice">@Model.StatusMessage</div>
}

<section class="card">
    <div class="card__header">
        <div>
            <p class="eyebrow">Plans</p>
            <h3>所有套餐</h3>
        </div>
        <span class="metric">@Model.State.Plans.Count</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>套餐 ID</th>
                    <th>名称</th>
                    <th>价格</th>
                    <th>配额</th>
                    <th>周期</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var plan in Model.State.Plans)
            {
                <tr>
                    <td><strong>@plan.PlanId</strong></td>
                    <td>@plan.Name</td>
                    <td>
                        @if (plan.MonthPrice.HasValue) { <div>月: @currency@plan.MonthPrice.Value.ToString("0.00")</div> }
                        @if (plan.YearPrice.HasValue) { <div>年: @currency@plan.YearPrice.Value.ToString("0.00")</div> }
                    </td>
                    <td>@(plan.TransferEnableBytes / (1024.0 * 1024.0 * 1024.0)) GB</td>
                    <td>
                        @if (plan.QuarterPrice.HasValue) { <span class="badge badge--idle">季</span> }
                        @if (plan.HalfYearPrice.HasValue) { <span class="badge badge--idle">半年</span> }
                        @if (plan.OneTimePrice.HasValue) { <span class="badge badge--ok">一次性</span> }
                    </td>
                    <td class="table-actions">
                        <a class="button button--small" asp-action="Plan" asp-route-planId="@plan.PlanId">编辑</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>