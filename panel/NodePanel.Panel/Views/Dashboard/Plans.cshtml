@using NodePanel.Panel.Models
@model DashboardPageViewModel
@{
    ViewData["Title"] = "订阅套餐";
    var currency = Model.State.Settings.GetValueOrDefault("currency_symbol", "¥");
    if (string.IsNullOrWhiteSpace(currency))
    {
        currency = "¥";
    }
}

<section class="page-header">
    <div>
        <p class="eyebrow">Plans</p>
        <h2>订阅套餐</h2>
        <p class="muted">管理提供给用户的套餐定价、流量额度和可售周期。</p>
    </div>
    <div class="page-actions">
        <a class="button button--primary" asp-action="NewPlan">新建套餐</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice">@Model.StatusMessage</div>
}

<section class="card">
    <div class="card__header">
        <div>
            <p class="eyebrow">Plans</p>
            <h3>所有套餐</h3>
        </div>
        <span class="metric">@Model.State.Plans.Count</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>套餐 ID</th>
                    <th>名称</th>
                    <th>价格</th>
                    <th>流量</th>
                    <th>周期说明</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var plan in Model.State.Plans)
            {
                var cycles = PlanPresentation.GetAvailableCycles(plan);
                var resetSummary = PlanPresentation.GetResetSummary(plan);

                <tr>
                    <td><strong>@plan.PlanId</strong></td>
                    <td>@plan.Name</td>
                    <td>
                        @if (cycles.Count == 0)
                        {
                            <span class="muted">未配置</span>
                        }
                        else
                        {
                            @foreach (var option in cycles)
                            {
                                <div>@option.DisplayName: @PlanPresentation.FormatPrice(option.Price, currency)</div>
                            }
                        }
                    </td>
                    <td>
                        <div>@PlanPresentation.FormatTraffic(plan.TransferEnableBytes)</div>
                        @if (!string.IsNullOrWhiteSpace(resetSummary))
                        {
                            <div class="muted">@resetSummary</div>
                        }
                    </td>
                    <td>
                        @if (cycles.Count == 0)
                        {
                            <span class="muted">暂无可售周期</span>
                        }
                        else
                        {
                            @foreach (var option in cycles)
                            {
                                <div>
                                    <span class="badge badge--idle">@option.DisplayName</span>
                                    <span class="muted">@option.DurationText · @option.ResetText</span>
                                </div>
                            }
                        }
                    </td>
                    <td class="table-actions">
                        <a class="button button--small" asp-action="Plan" asp-route-planId="@plan.PlanId">编辑</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
