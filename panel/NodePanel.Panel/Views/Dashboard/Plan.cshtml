@using NodePanel.Panel.Models
@model PlanEditorViewModel
@{
    ViewData["Title"] = Model.IsEditMode ? $"编辑套餐 {Model.Form.PlanId}" : "新建套餐";
    var indexReturnUrl = Url.Action("Index", "Dashboard") ?? "/admin";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Plans</p>
        <h2>@(Model.IsEditMode ? "编辑套餐" : "新建套餐")</h2>
        <p class="muted">定义用户的流量额度、销售周期和重置方式。</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice">@Model.StatusMessage</div>
}

<form asp-action="SavePlan" method="post" class="form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IsEditMode" />
    <div asp-validation-summary="All" class="error-box"></div>

    <section class="card stack">
        <div class="card__header">
            <h3>基础信息</h3>
        </div>
        <div class="form-grid">
            <label>
                套餐 ID (全局唯一)
                <input asp-for="Form.PlanId" placeholder="例如: vip-plan" readonly="@(Model.IsEditMode)" required />
            </label>
            <label>
                显示名称
                <input asp-for="Form.Name" placeholder="例如: 专业版 500G" required />
            </label>
            <label>
                权限组 (Group ID)
                <select asp-for="Form.GroupId" required>
                    @if (Model.AvailableGroups.Count == 0)
                    {
                        <option value="">暂无配置，请前往权限组管理添加</option>
                    }
                    else
                    {
                        @foreach (var g in Model.AvailableGroups)
                        {
                            <option value="@g.GroupId">@g.Name (@g.GroupId)</option>
                        }
                    }
                </select>
            </label>
            <label class="form-grid__span-2">
                总可用流量
                <div style="display: flex; gap: 12px; align-items: stretch;">
                    <input asp-for="Form.TransferEnableValue" type="number" min="0" step="0.01" placeholder="例如: 500" required style="flex: 1 1 auto;" />
                    <select asp-for="Form.TransferEnableUnit" style="width: 140px;">
                        <option value="@PlanPresentation.TrafficUnitMb">MB</option>
                        <option value="@PlanPresentation.TrafficUnitGb">GB</option>
                        <option value="@PlanPresentation.TrafficUnitTb">TB</option>
                    </select>
                </div>
                <small>按 MB / GB / TB 录入即可，前台会自动显示为易读格式。</small>
            </label>
        </div>
    </section>

    <section class="card stack">
        <div class="card__header">
            <h3>定价设置 (元) <small class="muted" style="display:inline; font-weight:normal;">填写 0 表示免费；留空表示不支持该周期</small></h3>
        </div>
        <div class="form-grid">
            <label>
                月付价格
                <input asp-for="Form.MonthPrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
            <label>
                季付价格
                <input asp-for="Form.QuarterPrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
            <label>
                半年付价格
                <input asp-for="Form.HalfYearPrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
            <label>
                年付价格
                <input asp-for="Form.YearPrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
            <label>
                一次性价格
                <input asp-for="Form.OneTimePrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
            <label>
                流量重置包价格
                <input asp-for="Form.ResetPrice" type="number" min="0" step="0.01" placeholder="留空则不支持" />
            </label>
        </div>
    </section>

    <div class="page-actions">
        <button type="submit" class="button button--primary">保存套餐</button>
        <a class="button" href="@indexReturnUrl">返回总览</a>
    </div>
</form>

@if (Model.IsEditMode)
{
    <section class="card" style="margin-top: 24px; border-color: var(--admin-warn-border);">
        <div class="card__header">
            <h3>危险操作</h3>
        </div>
        <form asp-action="DeletePlan" asp-route-planId="@Model.Form.PlanId" method="post" onsubmit="return confirm('确定要删除这个套餐吗？这不会影响目前已经订阅该套餐的用户，但他们以后将无法在门户续费此套餐。');">
            @Html.AntiForgeryToken()
            <button type="submit" class="button" style="color: var(--admin-warn);">删除此套餐</button>
        </form>
    </section>
}
