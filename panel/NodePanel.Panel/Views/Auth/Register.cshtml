@model NodePanel.Panel.Models.RegisterRequest
@inject NodePanel.Panel.Services.PanelQueryService QueryService
@{
    Layout = null; 
    var state = await QueryService.BuildStateViewAsync(Context.RequestAborted);
    var siteName = state.Settings.GetValueOrDefault("site_name", "NodePanel");
    if (string.IsNullOrWhiteSpace(siteName)) siteName = "NodePanel";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>注册 - @siteName</title>
    <link rel="stylesheet" href="~/site.css" asp-append-version="true" />
    <style>
        .auth-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .auth-card {
            width: 100%;
            max-width: 440px;
            padding: 40px;
        }
        .auth-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .auth-header h1 {
            margin: 0 0 8px;
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(to right, #fff, var(--admin-muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .auth-header p {
            margin: 0;
            color: var(--admin-muted);
            font-size: 15px;
        }
        .login-link {
            display: block;
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: var(--admin-accent);
            text-decoration: none;
            font-weight: 500;
        }
        .login-link:hover {
            color: var(--admin-accent-hover);
            text-decoration: underline;
        }
        .auth-error {
            margin-bottom: 24px;
        }
    </style>
</head>
<body class="admin-body">
    <div class="auth-container">
        <div class="card auth-card">
            <div class="auth-header">
                <h1>创建账户</h1>
                <p>加入 @siteName 以管理您的节点与服务</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-box auth-error">
                    @Html.ValidationSummary(false, "")
                </div>
            }

            <form asp-action="Register" method="post" class="form">
                <div>
                    <label for="Email">邮箱地址</label>
                    <input id="Email" asp-for="Email" type="email" placeholder="admin@example.com" required autocomplete="email" />
                </div>

                <div>
                    <label for="Password">密码</label>
                    <input id="Password" asp-for="Password" type="password" placeholder="••••••••" required autocomplete="new-password" />
                </div>

                <div>
                    <label for="ConfirmPassword">确认密码</label>
                    <input id="ConfirmPassword" asp-for="ConfirmPassword" type="password" placeholder="••••••••" required autocomplete="new-password" />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">邀请码 (Invite Code, Optional)</label>
                    <input asp-for="InviteCode" class="form-control" placeholder="选填..." />
                </div>

                <button type="submit" class="button button--primary" style="width: 100%; margin-top: 16px;">注 册</button>
                <a href="/auth/login" class="login-link">已有账户？立即登录</a>
            </form>
        </div>
    </div>
</body>
</html>