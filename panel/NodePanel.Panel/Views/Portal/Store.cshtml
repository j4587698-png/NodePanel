@model NodePanel.Panel.Models.PortalStoreViewModel
@{
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
    ViewData["Title"] = "订阅商店";
}

<style>
    .store-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        margin-top: 24px;
    }
    .plan-card {
        background: var(--admin-bg);
        border: 1px solid var(--admin-border);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        flex-direction: column;
    }
    .plan-card__header {
        margin-bottom: 24px;
        text-align: center;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--admin-border);
    }
    .plan-card__header h3 {
        margin: 0;
        font-size: 24px;
        color: #fff;
    }
    .plan-card__price {
        font-size: 32px;
        font-weight: bold;
        color: var(--admin-accent);
        margin: 16px 0 8px;
    }
    .plan-card__desc {
        color: var(--admin-muted);
        font-size: 14px;
    }
    .plan-form {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .plan-form select {
        width: 100%;
        padding: 10px 12px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--admin-border);
        color: #fff;
        border-radius: 6px;
        outline: none;
    }
    .plan-form select:focus {
        border-color: var(--admin-accent);
    }
</style>

<div class="portal-card">
    <div style="margin-bottom: 1rem;">
        <h2 style="margin: 0 0 8px; color: #fff;">购买订阅套餐</h2>
        <p class="muted" style="margin: 0;">选择适合您的流量套餐及支付周期。</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="error-box" style="margin-bottom: 24px; background: rgba(255,255,255,0.05); color: #fff; border-color: var(--admin-border);">
            @Model.StatusMessage
        </div>
    }

    <div class="store-grid">
        @foreach (var plan in Model.Plans)
        {
            <div class="plan-card">
                <div class="plan-card__header">
                    <h3>@plan.Name</h3>
                    <div class="plan-card__price">@Model.CurrencySymbol@(plan.MonthPrice ?? plan.YearPrice ?? plan.OneTimePrice ?? 0) <span style="font-size: 14px; font-weight: normal; color: var(--admin-muted);">起</span></div>
                    <div class="plan-card__desc">包含 @(plan.TransferEnableBytes / (1024.0 * 1024 * 1024)) GB 高速流量</div>
                </div>

                <form class="plan-form" action="/user/checkout" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="planId" value="@plan.PlanId" />
                    
                    <select name="cycle">
                        @if (plan.MonthPrice.HasValue) { <option value="month">月付 - @Model.CurrencySymbol@plan.MonthPrice.Value.ToString("0.00")</option> }
                        @if (plan.QuarterPrice.HasValue) { <option value="quarter">季付 - @Model.CurrencySymbol@plan.QuarterPrice.Value.ToString("0.00")</option> }
                        @if (plan.HalfYearPrice.HasValue) { <option value="half_year">半年付 - @Model.CurrencySymbol@plan.HalfYearPrice.Value.ToString("0.00")</option> }
                        @if (plan.YearPrice.HasValue) { <option value="year">年付 - @Model.CurrencySymbol@plan.YearPrice.Value.ToString("0.00")</option> }
                        @if (plan.OneTimePrice.HasValue) { <option value="one_time">一次性 - @Model.CurrencySymbol@plan.OneTimePrice.Value.ToString("0.00")</option> }
                        @if (plan.ResetPrice.HasValue) { <option value="reset_price">流量重置包 - @Model.CurrencySymbol@plan.ResetPrice.Value.ToString("0.00")</option> }
                    </select>

                    <button type="submit" class="button button--primary" style="width: 100%;">立即下单</button>
                </form>
            </div>
        }
        @if (Model.Plans.Count == 0)
        {
            <div style="color: var(--admin-muted); grid-column: 1 / -1; text-align: center; padding: 48px;">
                暂无可售套餐
            </div>
        }
    </div>
</div>
