{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "NodePanel": {
    "PanelUrl": "",
    "CachedConfigPath": "node-runtime-config.json",
    "Identity": {
      "NodeId": ""
    },
    "ControlPlane": {
      "Enabled": true,
      "Url": "",
      "AccessToken": "",
      "ConnectTimeoutSeconds": 10,
      "HeartbeatIntervalSeconds": 15,
      "ReconnectDelaySeconds": 5
    },
    "Bootstrap": {
      "TcpTls": {
        "Enabled": false,
        "ListenAddress": "0.0.0.0",
        "Port": 443,
        "HandshakeTimeoutSeconds": 10
      },
      "Wss": {
        "Enabled": false,
        "ListenAddress": "0.0.0.0",
        "Port": 8443,
        "Path": "/ws",
        "HandshakeTimeoutSeconds": 10
      },
      "Certificate": {
        "PfxPath": "",
        "PfxPassword": ""
      },
      "Limits": {
        "GlobalBytesPerSecond": 0,
        "ConnectTimeoutSeconds": 10
      },
      "Telemetry": {
        "FlushIntervalSeconds": 15
      },
      "Users": []
    }
  }
}
